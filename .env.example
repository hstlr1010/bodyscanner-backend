# Copy to .env and fill in real values

# JWT — must match bizbozz JWT_SECRET_BUSINESS
JWT_SECRET_BUSINESS=REPLACE_ME
JWT_ALGORITHM=HS256
JWT_AUDIENCE=business-app
JWT_ISSUER=gymheros

# Database (PostgreSQL recommended for prod, SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./bodyscanner.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bodyscanner

# File storage (local path or S3-compatible URL)
MESH_STORAGE_PATH=./meshes
# S3_BUCKET=bodyscanner-meshes
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# HMR2.0 model checkpoint path (downloaded separately — see README)
HMR2_CHECKPOINT=./checkpoints/hmr2.0a.ckpt

# Optional: maximum video upload size in MB
MAX_VIDEO_SIZE_MB=200
